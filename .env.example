# Browser-safe public configuration only.
# Never place service-role keys, provider API keys, passwords, or private tokens in Vite env vars.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# v0.3 Agent Runtime: leave blank for local mock stream on GitHub Pages.
VITE_AI_GATEWAY_URL=
VITE_AI_PROVIDER=mock
VITE_AI_MODEL=gateway/mock-stream
